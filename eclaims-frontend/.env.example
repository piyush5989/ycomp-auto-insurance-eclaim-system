# Copy this file to .env.local and fill in real values for local overrides.
# These are baked into the Vite bundle at build time — not secrets.
# For Docker / CI, pass as build-args (see docker-compose.app.yml and ci.yml).

# Keycloak OIDC endpoint — must be browser-accessible (not a Docker-internal hostname)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=eclaims
VITE_KEYCLOAK_CLIENT_ID=eclaims-web
