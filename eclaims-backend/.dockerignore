# Maven build output
**/target/
*.jar
*.war

# IDE files
.idea/
*.iml
.vscode/

# OS artefacts
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Local env overrides (never bake secrets into the image)
.env
.env.local

# Uploads (runtime data, not source)
uploads/

# Test reports (already uploaded as CI artefacts)
**/surefire-reports/
**/failsafe-reports/

# Docker files themselves (no need to copy into the image)
Dockerfile
.dockerignore
docker-compose*.yml
