#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper startup script, for POSIX shells.
# ----------------------------------------------------------------------------

set -eu

BASE_DIR="$(cd "$(dirname "$0")" && pwd)"
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
PROPERTIES_FILE="$WRAPPER_DIR/maven-wrapper.properties"
WRAPPER_JAR="$WRAPPER_DIR/maven-wrapper.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
  if [ ! -d "$WRAPPER_DIR" ]; then
    mkdir -p "$WRAPPER_DIR"
  fi
  if [ ! -f "$PROPERTIES_FILE" ]; then
    echo "Maven wrapper properties not found: $PROPERTIES_FILE" >&2
    exit 1
  fi
  WRAPPER_URL="$(grep -E '^wrapperUrl=' "$PROPERTIES_FILE" | sed -e 's/^wrapperUrl=//')"
  if [ -z "$WRAPPER_URL" ]; then
    WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
  fi
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$WRAPPER_URL" -o "$WRAPPER_JAR"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$WRAPPER_URL" -O "$WRAPPER_JAR"
  else
    echo "Neither curl nor wget found to download Maven Wrapper JAR." >&2
    exit 1
  fi
fi

exec ${JAVA_HOME:+$JAVA_HOME/bin/}java \
  -Dmaven.multiModuleProjectDirectory="$BASE_DIR" \
  -classpath "$WRAPPER_JAR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"

