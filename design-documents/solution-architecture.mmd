---
config:
  layout: elk
---
flowchart TB
    %% --- Users ---
    users["Users<br/>(Web, Mobile, Internal)"]

    %% --- Internet & Edge ---
    subgraph INTERNET["Internet & Edge Infrastructure"]
        direction TB
        dns["DNS<br/>(Route 53)"]
        cdn["CDN<br/>(CloudFront)"]
        waf["Web Application Firewall<br/>(AWS WAF)"]
    end

    %% --- Load Balancing ---
    alb["Application Load Balancer<br/>(AWS ALB)"]

    %% --- Presentation Layer ---
    subgraph PRESENTATION["Presentation Layer"]
        direction TB
        webApp["Customer Portal<br/>(React Web App)"]
        mobileApp["Mobile App<br/>(React Native)"]
        internalPortal["Internal Portal<br/>(React Admin)"]
        workshopPortal["Workshop Portal<br/>(React Web)"]
    end

    %% --- API Gateway & Identity ---
    subgraph GATEWAY["API Gateway & Identity"]
        direction LR
        apiGateway["API Gateway<br/>(Amazon API Gateway)<br/>Rate Limiting & Throttling"]
        identity["Identity Management<br/>(AWS Cognito + Keycloak)<br/>OAuth2, OIDC, RBAC, 200M Users"]
    end

    %% --- Microservices ---
    subgraph SERVICES["Microservices (ECS Fargate)"]
        direction TB
        claimsService["Claims Service<br/>(Spring Boot + Java 21)"]
        workflowService["Workflow Service<br/>(Camunda 8 BPMN)"]
        documentService["Document Service<br/>(Spring Boot + OCR)"]
        paymentService["Payment Service<br/>(Spring Boot + Stripe Connect)"]
        reportingService["Reporting Service<br/>(Spring Boot + Analytics)"]
        notificationService["Notification Service<br/>(Node.js + Multi-channel)"]
    end

    %% --- Data & Messaging ---
    subgraph DATA["Data & Messaging"]
        direction LR
        database["Amazon Aurora PostgreSQL<br/>(Multi-AZ + Read Replicas)"]
        cache["Amazon ElastiCache Redis<br/>(Cluster Mode)"]
        fileStorage["Amazon S3 + Object Lock<br/>(WORM Compliance)"]
        eventBus["Amazon MSK<br/>(Managed Kafka)"]
    end

    %% --- External Systems ---
    subgraph EXTERNAL["External Systems"]
        direction TB
        policySystem["Legacy Policy System<br/>(REST API Integration)"]
        paymentGateway["Stripe Connect<br/>(Marketplace Payments)"]
        emailService["Amazon SES<br/>(Transactional Email)"]
        smsService["Amazon SNS + Twilio<br/>(Multi-provider SMS)"]
        pushService["Firebase Cloud Messaging<br/>(Mobile Push)"]
    end

    %% --- Monitoring ---
    subgraph MONITORING["Monitoring & Observability"]
        direction LR
        monitoring["CloudWatch + X-Ray + Grafana<br/>Metrics, Logs, Tracing"]
        health["Health Checks + PagerDuty<br/>24x7 Alerting"]
    end

    %% --- Primary Flow ---
    users -- "Access via DNS" --> dns
    dns -- "Resolves request" --> cdn
    cdn -- "Delivers content or forwards" --> waf
    waf -- "Passes secure traffic" --> alb
    alb -- "Routes front-end HTTPS" --> PRESENTATION

    PRESENTATION -->|"API Calls" | apiGateway
    apiGateway <-->|"Auth & Tokens"| identity

    apiGateway -->|"Routes requests"| SERVICES

    SERVICES -->|"Publishes Events"| eventBus
    SERVICES -->|"Reads/Writes"| database
    SERVICES -->|"Uses Cache"| cache
    documentService -->|"Uploads Files"| fileStorage

    SERVICES -->|"Integrates with"| EXTERNAL

    notificationService -->|"Sends"| emailService
    notificationService -->|"Sends"| smsService
    notificationService -->|"Sends"| pushService

    SERVICES -->|"Monitored by"| monitoring
    monitoring -->|"Health Status"| health

    %% --- Styling ---
    classDef user fill:#eef2ff,stroke:#818cf8
    classDef infrastructure fill:#f0fdfa,stroke:#2dd4bf
    classDef presentation fill:#f5f3ff,stroke:#a78bfa
    classDef gateway fill:#fff7ed,stroke:#fb923c
    classDef service fill:#fdf4ff,stroke:#e879f9
    classDef data fill:#ecfeff,stroke:#22d3ee
    classDef external fill:#f7fee7,stroke:#a3e635
    classDef monitoring fill:#fff1f2,stroke:#fb7185

    class users user
    class dns,cdn,waf,alb infrastructure
    class PRESENTATION presentation
    class apiGateway,identity gateway
    class SERVICES service
    class DATA data
    class EXTERNAL external
    class MONITORING monitoring